{
  "expo": {
    "name": "E-Pasien Standard",
    "slug": "mobile-epasien-standard",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logors.png",
    "scheme": "mobileepasienstandard",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logors.png",
      "resizeMode": "contain",
      "backgroundColor": "#004d40"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.standard.epasien",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    }
  }
}
